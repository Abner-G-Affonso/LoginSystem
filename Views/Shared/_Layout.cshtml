<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LoginSystem</title>

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <div class="app">

        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="logo">
                <h2>LoginSystem</h2>
            </div>

            <nav>
                <a href="/Home">🏠 Dashboard</a>
                <a href="/User/Register">👤 Usuários</a>
                <a href="/Login">🔐 Login</a>
                <a href="/Home/Logout">🚪 Sair</a>
            </nav>
        </aside>

        <!-- CONTEÚDO -->
        <div class="main">

            <!-- TOPBAR -->
            <header class="topbar">
                <div>
                    Bem-vindo, @ViewBag.User?.Name
                </div>
            </header>

            <!-- PAGE CONTENT -->
            <section class="content">
                @RenderBody()
            </section>

        </div>

    </div>

</body>
</html>